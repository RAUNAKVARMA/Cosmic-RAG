# Copy to .env and fill in. Keys stay server-side only — never expose in the frontend.

# Default model: auto | ollama-llama3.2-1b | llama-4-maverick | mistral-medium-3.5 | qwen3.5-122b | etc.
LLM_DEFAULT_MODEL=auto

# Local Ollama (no API key) — install from https://ollama.com then: ollama pull llama3.2:1b
OLLAMA_BASE_URL=http://localhost:11434
# Render (deployed): set on cosmic-rag-api to your Ollama service URL, e.g.
# OLLAMA_BASE_URL=https://cosmic-rag-ollama.onrender.com
OLLAMA_MODEL=llama3.2:1b

# NVIDIA NIM cloud — https://build.nvidia.com/
# Powers all NIM models (llama-4-maverick, mistral-medium-3.5, qwen3.5-122b, nemotron-ultra, deepseek-v4-pro, diffusiongemma-26b)
NVIDIA_API_KEY=nvapi_your_key_here

# DeepSeek — https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk_your_key_here

# Groq — https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# OpenAI — https://platform.openai.com/
OPENAI_API_KEY=sk_your_key_here

# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant_your_key_here

# Google Gemini — https://aistudio.google.com/apikey
# Powers the "Gemini (Nano Banana)" image model in Image Studio (hosted, no GPU).
GEMINI_API_KEY=your_gemini_key_here
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Cloudflare Workers AI — https://dash.cloudflare.com/profile/api-tokens
# Token needs Account → Workers AI permission.
# CLOUDFLARE_ACCOUNT_ID=your_account_id
# CLOUDFLARE_API_TOKEN=your_cloudflare_token

# Replicate — https://replicate.com/account/api-tokens
# Powers FLUX / SDXL models in Image Studio (hosted, no GPU).
REPLICATE_API_KEY=r8_your_replicate_key_here

# Pollinations — https://enter.pollinations.ai (required for image generation)
# Secret key (sk_...) for server-side use. Powers FLUX, Z-Image, Nano Banana, etc.
POLLINATIONS_API_KEY=sk_your_pollinations_key_here

# Optional: comma-separated browser origins (defaults include localhost:3000-3003)
# ALLOWED_ORIGINS=http://localhost:3000

# ── Production security (recommended on Render) ─────────────────────
# Shared secret for POST /chat, /upload, /generate-image. Leave unset for local dev.
# API_SECRET=generate_a_long_random_string_here
# Max image generations per IP per window (default: 10 per hour)
# IMAGE_GEN_RATE_LIMIT=10
# IMAGE_GEN_RATE_WINDOW_SECONDS=3600

# ── Persistent RAG index (Render) ───────────────────────────────────
# Mount a disk at /data and set:
# VECTOR_INDEX_PATH=/data/vector_index

# ── Database (Render PostgreSQL or local SQLite) ──────────────────────
# On Render Blueprint, DATABASE_URL is set automatically from cosmic-rag-db.
# Locally, SQLite is used automatically (./cosmic_rag.db).
# DATABASE_URL=postgresql://user:pass@host:5432/cosmic_rag

# Ollama health check timeout in seconds (Render cold starts need ~15s)
# OLLAMA_HEALTH_TIMEOUT=15

# ── Image generation (NVIDIA Visual GenAI) ───────────────────────────
# Two ways to power the Image Studio (see backend/IMAGE_MODELS.md):
#
# 1. HOSTED (no GPU needed): just set NVIDIA_API_KEY above. The backend calls
#    build.nvidia.com automatically. Note: hosted image endpoints may be limited
#    on the free tier (404 "Function not found") — the UI shows a clear message.
#
# 2. SELF-HOSTED NIMs: run the containers and point these at them. A *_NIM_URL
#    override always takes priority over the hosted API for that model.
#    If a NIM uses port 8000 it clashes with this API — map it elsewhere
#    (e.g. -p 8100:8000) and set the URL accordingly.
# SD35_NIM_URL=http://localhost:8100/v1/infer
# FLUX_NIM_URL=http://localhost:8101/v1/infer
# QWEN_IMAGE_NIM_URL=http://localhost:8102/v1/infer
# TRELLIS_NIM_URL=http://localhost:8103/v1/infer
# Max seconds to wait for a generation (NIM warmup can take minutes on first call)
# IMAGE_GEN_TIMEOUT=300
