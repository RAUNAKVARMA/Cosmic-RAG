# Copy to .env and fill in. Keys stay server-side only — never expose in the frontend.

# Default model: auto | ollama:llama3.1 | nvidia:nemotron | deepseek:chat | groq:llama
LLM_DEFAULT_MODEL=auto

# Local Ollama (no API key)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# NVIDIA NIM — https://build.nvidia.com/
NVIDIA_API_KEY=nvapi_your_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# DeepSeek — https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk_your_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Groq (optional fallback) — https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: comma-separated browser origins (defaults include localhost:3000-3003)
# ALLOWED_ORIGINS=http://localhost:3000
