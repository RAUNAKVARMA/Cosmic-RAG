# Copy to .env and fill in. Keys stay server-side only — never expose in the frontend.

# Default model: auto | ollama-llama3.2-1b | llama-4-maverick | mistral-medium-3.5 | qwen3.5-122b | etc.
LLM_DEFAULT_MODEL=auto

# Local Ollama (no API key) — install from https://ollama.com then: ollama pull llama3.2:1b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# NVIDIA NIM cloud — https://build.nvidia.com/
# Powers all NIM models (llama-4-maverick, mistral-medium-3.5, qwen3.5-122b, nemotron-ultra, deepseek-v4-pro, diffusiongemma-26b)
NVIDIA_API_KEY=nvapi_your_key_here

# DeepSeek — https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk_your_key_here

# Groq — https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# OpenAI — https://platform.openai.com/
OPENAI_API_KEY=sk_your_key_here

# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant_your_key_here

# Optional: comma-separated browser origins (defaults include localhost:3000-3003)
# ALLOWED_ORIGINS=http://localhost:3000
