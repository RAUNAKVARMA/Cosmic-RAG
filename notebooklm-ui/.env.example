# Local dev: leave unset to use /api/rag → proxy to http://127.0.0.1:8000
# Vercel: REQUIRED — your deployed FastAPI (e.g. Render)
# NEXT_PUBLIC_API_URL=https://cosmic-rag-api.onrender.com

# Must match backend API_SECRET when auth is enabled on Render (same value on both)
# NEXT_PUBLIC_API_SECRET=your_shared_secret_here
