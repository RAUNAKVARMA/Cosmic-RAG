# Local dev: leave unset — browser uses /api/rag → Next rewrites to http://127.0.0.1:8000

# Vercel (server-side proxy — preferred over NEXT_PUBLIC_API_URL):
# BACKEND_URL=https://cosmic-rag-api.onrender.com
# BACKEND_API_SECRET=<same value as API_SECRET on Render>

# Optional legacy direct client calls (not needed when using /api/rag proxy):
# NEXT_PUBLIC_API_URL=https://cosmic-rag-api.onrender.com
# NEXT_PUBLIC_API_SECRET=your_shared_secret_here
